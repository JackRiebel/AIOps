# Lumen Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Database Configuration
# =============================================================================
# Leave empty to use embedded PostgreSQL (recommended for getting started)
DATABASE_URL=

# =============================================================================
# AI Provider Configuration (at least one required)
# =============================================================================
# Anthropic Claude API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (optional, for GPT models)
OPENAI_API_KEY=

# =============================================================================
# Meraki Integration (optional)
# =============================================================================
MERAKI_API_KEY=your_meraki_api_key_here

# =============================================================================
# Splunk Integration (optional)
# =============================================================================
SPLUNK_HOST=
SPLUNK_PORT=8089
SPLUNK_USERNAME=
SPLUNK_PASSWORD=
SPLUNK_TOKEN=

# =============================================================================
# ThousandEyes Integration (optional)
# =============================================================================
THOUSANDEYES_OAUTH_TOKEN=

# =============================================================================
# Notification Integrations (optional)
# =============================================================================
# Slack
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

# Microsoft Teams
TEAMS_WEBHOOK_URL=

# PagerDuty
PAGERDUTY_API_KEY=
PAGERDUTY_ROUTING_KEY=

# Webex
WEBEX_WEBHOOK_URL=
WEBEX_BOT_TOKEN=

# =============================================================================
# Security Settings
# =============================================================================
# Secret key for session encryption (generate a random string)
SECRET_KEY=change_this_to_a_random_secret_key

# JWT settings
JWT_SECRET_KEY=change_this_to_another_random_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# =============================================================================
# Server Settings
# =============================================================================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# =============================================================================
# Embedding Service (for RAG/Knowledge Base)
# =============================================================================
# Leave empty to use Anthropic embeddings
EMBEDDING_MODEL=
